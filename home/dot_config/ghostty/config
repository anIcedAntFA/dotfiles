# ============================================================================
# Ghostty — main configuration
# ============================================================================
# Keybind model (see docs/adr/0008-terminal-workspace-model.md):
#   niri   owns  Super+*        (compositor grabs these before Ghostty)
#   Ghostty owns Alt+*, including the Alt+Space leader   <- this file
#   zellij owns  Ctrl-modal     (Ctrl+g/p/t/n/o/s…, passed straight through)
# Alt is "Ghostty's Super": it reuses the hjkl muscle memory built for niri.
# Ctrl+Tab is the one carve-out from zellij's Ctrl space (zellij doesn't bind it).

# --- Appearance -------------------------------------------------------------
# Ghostty watches the desktop light/dark setting and swaps between these two
# themes live. Each theme file also carries its own background-image, which is
# how the image follows the mode — background-image has no light:/dark: form of
# its own. See docs/ghostty.md.
theme = light:latte,dark:dracula

# Opaque window: depth comes from the background-image in the theme files, not
# from window transparency. background-opacity DOES work on niri, but Noctalia
# runs with the wallpaper disabled (a solid-colour desktop), so a see-through
# window would only pick up that flat colour. background-blur is a no-op on niri
# regardless (it needs the KDE/KWin blur protocol).
background-opacity = 1

# --- Font -------------------------------------------------------------------
font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font
font-family-italic = JetBrainsMono Nerd Font
font-family-bold-italic = JetBrainsMono Nerd Font
font-style = Medium
font-style-bold = SemiBold
font-style-italic = Medium
font-style-bold-italic = SemiBold
font-size = 13

# --- Cursor -----------------------------------------------------------------
cursor-style = bar
cursor-opacity = 1
adjust-cursor-thickness = 8
cursor-invert-fg-bg = false
cursor-click-to-move = true
cursor-style-blink = true
custom-shader = shaders/cursor_sweep.glsl

# --- Mouse ------------------------------------------------------------------
# Hide the mouse pointer the moment you type; it reappears on movement.
mouse-hide-while-typing = true

# Hover a pane to focus it. This deliberately disagrees with niri, which is
# click-to-focus: inside a Ghostty window the mouse focuses, between windows it
# does not. The cost is accepted for the hands-off-keyboard case. Note the two
# mouse options above/below do NOT conflict: focus only follows an actual
# pointer *movement*, and any movement un-hides the pointer.
focus-follows-mouse = true

# --- Links ------------------------------------------------------------------
# Preview only OSC 8 hyperlinks, where the link text may differ from the real
# destination — there the preview is the only way to see where you're going.
# On a plain URL the preview just echoes the text under the cursor, so it costs
# a row and tells you nothing. (`link`, which would let us match our own
# regexes, is documented but not settable as of 1.3.1.)
link-previews = osc8

# --- Shell integration ------------------------------------------------------
shell-integration = fish
shell-integration-features = no-cursor

# --- Window -----------------------------------------------------------------
gtk-titlebar = true
gtk-tabs-location = bottom
window-decoration = none
window-padding-x = 8
window-padding-y = 8
confirm-close-surface = true
window-save-state = always

# --- Updates ----------------------------------------------------------------
auto-update = check
auto-update-channel = stable

# --- Clipboard --------------------------------------------------------------
# Auto-copy the selection (classic terminal behaviour) and strip trailing
# whitespace so copied commands/code paste clean. Rich copy (text/plain +
# text/html) is automatic since 1.3.0, so pasting into a doc/blog keeps colours.
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# --- Notifications ----------------------------------------------------------
# Desktop notification when a long command finishes in an UNfocused surface
# (builds, tests, scripts running in another pane/tab).
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# ============================================================================
# KEYBINDS
# ============================================================================
# Convention: Alt = focus/act now, Alt+Shift = resize, Alt+Space = leader (rare).
# Splits are "panes". A note on shadowing: Ghostty consumes these before the
# terminal app, so Alt+h and Alt+l shadow fish's man-page / list-dir bindings.

# --- Splits (panes) ---------------------------------------------------------
keybind = alt+enter=new_split:right
keybind = alt+shift+enter=new_split:down
keybind = alt+z=toggle_split_zoom

# Focus a pane (mirrors niri Super+hjkl, one modifier down).
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up
keybind = alt+l=goto_split:right

# Resize the focused pane. 60px is ~2.3% of a 2560px monitor — fine for a nudge,
# painful for a real drag (9 presses for 20%). Hence the resize key table below,
# which keeps this step size but drops the modifier.
keybind = alt+shift+h=resize_split:left,60
keybind = alt+shift+j=resize_split:down,60
keybind = alt+shift+k=resize_split:up,60
keybind = alt+shift+l=resize_split:right,60

# --- Resize key table (sticky) ----------------------------------------------
# A key table is modal: unlike the leader below (one key, then over), it stays
# active until dismissed — and Ghostty draws NO indicator for it. See CONTEXT.md.
# catch_all is the safety net: any key other than hjkl/escape drops the mode, so
# you cannot get stuck. Worst case for typing `ls` while still in the table is
# one stray 2.3% nudge (undo with alt+space>e), not a dead window.
# The bindings above still work inside the table — lookup falls outward.
keybind = alt+space>r=activate_key_table:resize
keybind = resize/h=resize_split:left,60
keybind = resize/j=resize_split:down,60
keybind = resize/k=resize_split:up,60
keybind = resize/l=resize_split:right,60
keybind = resize/escape=deactivate_key_table
keybind = resize/catch_all=deactivate_key_table

# --- Tabs -------------------------------------------------------------------
keybind = alt+t=new_tab
keybind = alt+w=close_surface
keybind = alt+shift+w=close_tab
keybind = alt+r=prompt_tab_title
# alt+o, not alt+tab (that collided): zoomed-out grid of every tab.
keybind = alt+o=toggle_tab_overview
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Jump straight to a tab by number.
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=goto_tab:9

# --- Search -----------------------------------------------------------------
# alt+shift+f fits the Alt namespace; ctrl+shift+f (Ghostty default) still works.
keybind = alt+shift+f=start_search

# --- Leader (Alt+Space > key): infrequent ops -------------------------------
# `>` is a sequence, not a combo: press Alt+Space, release, then the next key.
# Ghostty waits indefinitely for it (no timeout), so the leader key itself never
# reaches the program — hence Alt+Space, which nothing else wants, rather than
# Ctrl+Space, which apps use (e.g. completion in editors).
keybind = alt+space>e=equalize_splits
keybind = alt+space>n=new_window
keybind = alt+space>comma=move_tab:-1
keybind = alt+space>period=move_tab:1
keybind = alt+space>b=scroll_to_bottom
keybind = alt+space>x=reload_config
