[core]
	excludesfile = ~/.gitignore
	ignorecase = false
	editor = nano

[push]
	default = simple

# Sign commits & tags with an SSH key (reuses your existing SSH key — no GPG).
# See docs/git.md. The work identity overrides signingkey in .gitconfig-company.
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true

[color]
	status = auto
	diff = auto
	branch = auto
	interactive = auto
	grep = auto
	ui = auto

[alias]
	g = git
	a = add
	co = checkout
	ci = commit
	ca = commit -a
	pr = pull --rebase
	st = status
	br = branch
	ba = branch -a
	bm = branch --merged
	bn = branch --no-merged
	bda = git branch | grep -v "develop" | grep -v "master" | grep -v "main" | xargs git branch -D

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[ghq "ssh://git@{{ .workGitHost }}:{{ .workGitPort }}/"]
	root = {{ .ghqCompanyRoot }}

[ghq]
	root = {{ .ghqRoot }}

[user]
	email = {{ .email }}
	name = {{ .name }}
	signingkey = ~/.ssh/github.pub

[includeIf "gitdir:{{ .ghqCompanyRoot }}/"]
	path = ./.gitconfig-company
